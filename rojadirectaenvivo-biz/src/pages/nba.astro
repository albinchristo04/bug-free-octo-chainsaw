---
import Base from '../layouts/Base.astro';
import MatchList from '../components/MatchList.astro';
import FaqBlock from '../components/FaqBlock.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { fetchSiteData } from '../lib/data';
import { sportHubTitle, orgSchema } from '../lib/seo';
import { hubFaqItems } from '../lib/faq';

const data = await fetchSiteData();
const matches = data.bySport['nba'] ?? [];
const faqItems = hubFaqItems('NBA', matches);
---
<Base title={sportHubTitle('NBA')} description={`NBA en vivo hoy. ${matches.length} partidos de baloncesto en directo gratis.`} schema={[orgSchema()]}>
  <div class="container">
    <Breadcrumb items={[{ name: 'NBA', href: '/nba/' }]} />
    <section class="hero"><h1>NBA En Vivo Hoy — Ver Baloncesto Gratis</h1></section>
    <section class="section">
      <h2 class="section-title">Partidos de NBA Hoy</h2>
      <MatchList matches={matches} groupByLeague={false} />
    </section>
    <FaqBlock items={faqItems} />
  </div>
</Base>
