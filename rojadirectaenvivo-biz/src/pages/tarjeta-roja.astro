---
import Base from '../layouts/Base.astro';
import MatchList from '../components/MatchList.astro';
import SeoText from '../components/SeoText.astro';
import { fetchSiteData } from '../lib/data';
import { tarjetaRojaTitle, tarjetaRojaMeta, orgSchema } from '../lib/seo';

const data = await fetchSiteData();
const title = tarjetaRojaTitle();
const description = tarjetaRojaMeta(data.matches.length);
---
<Base title={title} description={description} schema={[orgSchema()]}>
  <div class="container">
    <section class="hero">
      <h1>Tarjeta Roja TV en Vivo — Ver Partidos Gratis</h1>
      <p>Tarjeta Roja TV es otro nombre para acceder a los mismos partidos en vivo. Aqui puedes ver todos los deportes disponibles hoy.</p>
    </section>
    <section class="section">
      <h2 class="section-title">Partidos Disponibles Hoy</h2>
      <MatchList matches={data.matches} groupByLeague={true} />
    </section>
    <SeoText text={`Tarjeta Roja TV en vivo gratis. ${data.matches.length} partidos disponibles hoy: fútbol, béisbol MLB, baloncesto NBA, hockey NHL y MotoGP. Tarjeta Roja Pirlo TV · Tarjeta Roja MLB · Tarjeta Roja en Vivo.`} />
  </div>
</Base>
