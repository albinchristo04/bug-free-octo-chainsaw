---
import Base from '../layouts/Base.astro';
import MatchList from '../components/MatchList.astro';
import { fetchSiteData } from '../lib/data';
import { orgSchema } from '../lib/seo';
import { SITE_NAME } from '../lib/config';

const data = await fetchSiteData();
---
<Base
  title={`Tarjeta Roja Pirlo TV En Vivo - Ver Partidos Gratis | ${SITE_NAME}`}
  description={`Tarjeta Roja Pirlo TV en vivo gratis. Ver fútbol y deportes en directo. ${data.matches.length} partidos disponibles hoy.`}
  schema={[orgSchema()]}
>
  <div class="container">
    <section class="hero">
      <h1>Tarjeta Roja Pirlo TV — Ver Partidos en Vivo Gratis</h1>
    </section>
    <section class="section">
      <h2 class="section-title">Partidos Disponibles Hoy</h2>
      <MatchList matches={data.matches} groupByLeague={true} />
    </section>
  </div>
</Base>
