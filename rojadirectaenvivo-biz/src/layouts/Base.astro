---
// src/layouts/Base.astro
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE_URL, SITE_NAME } from '../lib/config';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  ogDescription?: string;
  preconnect?: string;
}

const { title, description, canonical, schema, ogDescription, preconnect } = Astro.props;
const canonicalUrl = canonical ?? Astro.url.href;
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={SITE_NAME} />

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={ogDescription ?? description} />

  <link rel="alternate" type="application/rss+xml" title="Partidos en Vivo" href="/feed.xml" />
  <link rel="manifest" href="/manifest.json" />

  {preconnect && (
    <>
      <link rel="preconnect" href={preconnect} />
      <link rel="dns-prefetch" href={preconnect} />
    </>
  )}

  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
